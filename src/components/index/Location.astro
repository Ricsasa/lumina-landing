---
import { Image } from "astro:assets";

import { MapPinIcon } from "@heroicons/react/24/outline";

import Facilities1 from "../../assets/facilities/facilities-1.avif";
import Facilities2 from "../../assets/facilities/facilities-2.avif";
---

<section
    class="flex flex-col items-center md:px-6 scroll-mt-24 py-20 w-full"
    id="ubicacion"
>
    <div class="mx-auto max-w-3xl text-center mb-12">
        <h2
            class="text-3xl md:text-5xl font-medium tracking-tight text-custom-piel dark:text-custom-beige font-fira"
        >
            Nuestra Ubicación
        </h2>
        <p
            class="mt-4 text-base md:text-lg text-custom-piel/70 dark:text-custom-beige/70 font-light"
        >
            Visítanos en nuestras instalaciones.
        </p>
    </div>

    <div
        class="w-[calc(100vw-2em)] max-w-5xl mx-auto flex flex-col md:flex-row gap-6 md:gap-8"
    >
        <!-- Images Section Card -->
        <div
            class="relative w-full md:w-1/3 flex overflow-hidden bg-custom-beige-light dark:bg-custom-oscuro rounded-[32px] shadow-sm border border-custom-piel/10 dark:border-custom-beige/20 hover:dark:border-custom-beige/40 transition-colors duration-300"
        >
            <Image
                src={Facilities1}
                alt={"Interior"}
                class="gsap-facility-image relative w-full h-auto md:absolute md:top-0 md:left-0 md:h-full object-cover opacity-0"
            />
            <Image
                src={Facilities2}
                alt={"Exterior"}
                class="gsap-facility-image absolute top-0 left-0 w-full h-full object-cover opacity-0"
            />
        </div>

        <!-- Info & Map Section Card -->
        <div
            class="flex flex-col grow p-6 md:p-8 lg:p-10 bg-custom-beige-light dark:bg-custom-oscuro rounded-[32px] shadow-sm border border-custom-piel/10 dark:border-custom-beige/20 hover:dark:border-custom-beige/40 transition-colors duration-300"
        >
            <a
                href="https://maps.app.goo.gl/oHGPfz5yCKV8uaas6"
                target="_blank"
                rel="noopener noreferrer"
                class="group block mb-8"
            >
                <div
                    class="flex items-start gap-4 p-6 bg-custom-piel/5 dark:bg-custom-beige/5 rounded-[24px] hover:bg-custom-piel/10 dark:hover:bg-custom-beige/10 transition-colors duration-300"
                >
                    <div class="shrink-0 mt-1">
                        <MapPinIcon
                            width={32}
                            className="text-custom-piel dark:text-custom-beige"
                        />
                    </div>
                    <div>
                        <h3
                            class="text-lg font-medium text-custom-piel dark:text-custom-beige mb-1 font-fira group-hover:underline"
                        >
                            Lumina Estudio Láser
                        </h3>
                        <p
                            class="text-sm md:text-base text-custom-piel/80 dark:text-custom-beige/80 font-light leading-relaxed whitespace-pre-line text-left"
                        >
                            {
                                "Osa Menor 3744-c, La Calma\n45070, Zapopan, Jalisco"
                            }
                        </p>
                    </div>
                </div>
            </a>

            <div
                class="w-full relative pt-[56.25%] rounded-[24px] overflow-hidden border border-custom-piel/10 dark:border-custom-beige/10 bg-custom-piel/5 shrink-0 mb-8"
            >
                <iframe
                    title="Google Maps location"
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3733.838113524611!2d-103.41961868784156!3d20.63545440108885!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6ac0681e7d5675af%3A0xb1cbbe507bc95e60!2sLumina%20estudio%20l%C3%A1ser!5e0!3m2!1ses!2smx!4v1771544943218!5m2!1ses!2smx"
                    class="absolute top-0 left-0 w-full h-full"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>

            <div
                class="flex items-start gap-4 p-6 bg-custom-piel/5 dark:bg-custom-beige/5 rounded-[24px] hover:bg-custom-piel/10 dark:hover:bg-custom-beige/10 transition-colors duration-300"
            >
                <div class="shrink-0 mt-1">
                    <MapPinIcon
                        width={32}
                        className="text-custom-piel dark:text-custom-beige"
                    />
                </div>
                <div>
                    <h3
                        class="text-lg font-medium text-custom-piel dark:text-custom-beige mb-1 font-fira group-hover:underline"
                    >
                        Lumina Estudio Láser
                    </h3>
                    <p
                        class="text-sm md:text-base text-custom-piel/80 dark:text-custom-beige/80 font-light leading-relaxed whitespace-pre-line text-left"
                    >
                        {"Osa Menor 3744-c, La Calma\n45070, Zapopan, Jalisco"}
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    const images = document.querySelectorAll(".gsap-facility-image");

    if (images.length > 0) {
        const tl = gsap.timeline({ repeat: -1 });

        tl.to(images, {
            opacity: 1,
            duration: 1,
            stagger: 2,
        }).to(
            images,
            {
                opacity: 0,
                duration: 1,
                stagger: 2,
            },
            1,
        );
    }
</script>
