---
import { Image } from "astro:assets";

interface Props {
    title: string;
    image: any;
    href: string;
    className?: string;
}

const { title, image, href, className } = Astro.props;
---

<div
    class={`group flex flex-col w-full max-w-[264px] sm:max-w-sm md:max-w-none mx-auto overflow-hidden bg-custom-beige-light dark:bg-custom-oscuro rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-custom-piel/10 dark:border-custom-beige/20 hover:border-custom-piel/30 dark:hover:border-custom-beige/40 ${className || ""}`}
>
    <a href={href} class="relative block overflow-hidden">
        <Image
            class="object-cover w-full h-44 sm:h-56 md:h-60 lg:h-64 transition-transform duration-700 group-hover:scale-105 saturate-60"
            src={image}
            alt={title}
            title={title}
            format="avif"
        />
        <div
            class="absolute inset-x-0 bottom-0 h-2/3 bg-linear-to-t from-custom-beige-light dark:from-custom-oscuro via-custom-beige-light/60 dark:via-custom-oscuro/60 to-transparent pointer-events-none"
        >
        </div>
    </a>
    <div
        class="flex flex-col grow px-4 pb-4 sm:px-6 sm:pb-6 md:px-8 md:pb-8 pt-0 md:pt-0 -mt-3 sm:-mt-4 md:-mt-2 relative z-10"
    >
        <a href={href}>
            <h3
                class="mb-4 sm:mb-6 text-xl sm:text-2xl md:text-3xl font-medium tracking-tight text-custom-piel dark:text-custom-beige font-fira"
            >
                {title}
            </h3>
        </a>

        <div class="mt-auto">
            <a
                href={href}
                class="w-full inline-flex items-center justify-center px-4 py-3 sm:px-6 sm:py-3.5 text-[14px] sm:text-[15px] font-medium tracking-wide transition-colors duration-300 rounded-full bg-custom-piel/10 text-custom-oscuro hover:bg-custom-piel/20 dark:bg-custom-piel/20 dark:text-custom-piel hover:dark:bg-custom-beige focus:outline-none focus:ring-2 focus:ring-custom-piel/50"
            >
                <span>Saber más</span>
                <svg
                    class="w-4 h-4 ml-2 -mr-1 rtl:mr-2 rtl:-ml-1"
                    aria-hidden="true"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 12H5m14 0-4 4m4-4-4-4"></path>
                </svg>
            </a>
        </div>
    </div>
</div>
