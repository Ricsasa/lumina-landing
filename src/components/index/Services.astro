---
import Eyebrows from "../../assets/services/eyebrows.avif";
import Dermapen from "../../assets/services/dermapen.avif";
import Hollywood from "../../assets/services/hollywood.avif";
import Tattoo from "../../assets/services/tattoo.avif";
import Armpit from "../../assets/services/armpit2.avif";
import ServiceCard from "./ServiceCard.astro";

const services = [
    {
        title: "Eliminación de tatuajes",
        image: Tattoo,
        className: "md:col-span-6",
        href: "/eliminacion-de-tatuajes",
    },
    {
        title: "Eliminación de micropigmentación",
        image: Eyebrows,
        className: "md:col-span-6",
        href: "/eliminacion-micropigmentacion",
    },
    {
        title: "Despigmentación facial y corporal",
        image: Armpit,
        className: "md:col-span-4",
        href: "/despigmentacion",
    },
    {
        title: "Hollywood Peel",
        image: Hollywood,
        className: "md:col-span-4",
        href: "/hollywood-peel",
    },
    {
        title: "Microneedling (Dermapen)",
        image: Dermapen,
        className: "md:col-span-4",
        href: "/microneedling",
    },
];
---

<section class="flex items-center md:px-6 py-12 flex-col w-full" id="servicios">
    <div class="py-8 mx-auto lg:py-16 w-full container max-w-6xl">
        <div class="mx-auto max-w-screen-sm text-center mb-12">
            <h2
                class="text-3xl md:text-5xl font-medium tracking-tight text-custom-piel dark:text-custom-beige font-fira"
            >
                Nuestros Servicios
            </h2>
            <p
                class="mt-4 text-base md:text-lg text-custom-oscuro dark:text-custom-piel font-light"
            >
                Descubre nuestra gama de tratamientos láser y de cuidado de la
                piel.
            </p>
        </div>

        <div
            class="flex flex-col md:grid md:grid-cols-12 gap-4 md:gap-6 lg:gap-8 w-full"
        >
            {services.map((service) => <ServiceCard {...service} />)}
        </div>
    </div>
</section>
