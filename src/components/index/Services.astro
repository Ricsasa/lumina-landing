---
import { Image } from "astro:assets";
import Eyebrows from "../../assets/services/eyebrows.avif";
import Dermapen from "../../assets/services/dermapen.avif";
import Hollywood from "../../assets/services/hollywood.avif";
import Tattoo from "../../assets/services/tattoo.avif";
import Armpit from "../../assets/services/armpit2.avif";

const services = [
    {
        title: "Eliminación de tatuajes",
        image: Tattoo,
        className: "md:col-span-4",
        href: "/eliminacion-de-tatuajes",
    },
    {
        title: "Eliminación de micropigmentación",
        image: Eyebrows,
        className: "md:col-span-4",
        href: "/eliminacion-micropigmentacion",
    },
    {
        title: "Despigmentación facial y corporal",
        image: Armpit,
        className: "md:col-span-4",
        href: "/despigmentacion",
    },
    {
        title: "Hollywood Peel",
        image: Hollywood,
        className: "md:col-start-3 md:col-span-4",
        href: "/hollywood-peel",
    },
    {
        title: "Microneedling (Dermapen)",
        image: Dermapen,
        className: "md:col-span-4",
        href: "/microneedling",
    },
];
---

<section class="flex items-center md:px-6 py-12 flex-col w-full" id="servicios">
    <div class="py-8 mx-auto lg:py-16 w-full container max-w-7xl">
        <div class="mx-auto max-w-screen-sm text-center mb-12">
            <h2
                class="text-3xl md:text-5xl font-medium tracking-tight text-custom-piel dark:text-custom-beige font-fira"
            >
                Nuestros Servicios
            </h2>
            <p
                class="mt-4 text-base md:text-lg text-custom-piel/70 dark:text-custom-beige/70 font-light"
            >
                Descubre nuestra gama de tratamientos láser y de cuidado de la
                piel.
            </p>
        </div>

        <div
            class="flex flex-col md:grid md:grid-cols-12 gap-4 md:gap-6 lg:gap-8 w-full"
        >
            {
                services.map((service) => (
                    <div
                        class={`flex flex-col w-full max-w-sm md:max-w-none mx-auto overflow-hidden bg-custom-beige-light dark:bg-custom-oscuro rounded-[24px] shadow-sm hover:shadow-md transition-shadow duration-300 border border-custom-piel/10 dark:border-custom-beige/20 hover:dark:border-custom-beige/40 ${service.className || ""}`}
                    >
                        <a
                            href={service.href}
                            class="relative block overflow-hidden"
                        >
                            <Image
                                class="object-cover w-full h-48 sm:h-56 md:h-72 lg:h-88 transition-transform duration-500 hover:scale-105 saturate-60"
                                src={service.image}
                                alt={service.title}
                            />
                        </a>
                        <div class="flex flex-col grow p-6">
                            <a href={service.href}>
                                <h3 class="mb-2 text-xl font-medium tracking-tight text-custom-piel dark:text-custom-beige font-fira">
                                    {service.title}
                                </h3>
                            </a>

                            <div class="mt-auto">
                                <a
                                    href={service.href}
                                    class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium tracking-wide transition-colors duration-300 rounded-full bg-custom-piel/10 text-custom-piel hover:bg-custom-piel/20 dark:bg-custom-piel/20 dark:text-custom-beige dark:hover:bg-custom-piel/30 focus:outline-none focus:ring-2 focus:ring-custom-piel/50"
                                >
                                    Saber más
                                    <svg
                                        class="w-4 h-4 ml-2 -mr-1 rtl:mr-2 rtl:-ml-1"
                                        aria-hidden="true"
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke="currentColor"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 12H5m14 0-4 4m4-4-4-4"
                                        />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
