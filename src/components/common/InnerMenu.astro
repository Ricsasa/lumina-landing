---
interface Props {
    title: string;
    menuItems: {
        title: string;
        icon: any;
        href: string;
    }[];
}

const { menuItems } = Astro.props;
---

<nav
    class="sticky top-20 mt-20 w-full bg-transparent backdrop-blur-md border-b border-custom-beige/10 z-50 transition-all duration-300"
>
    <div
        class="flex justify-center md:justify-center gap-2 md:gap-12 items-center h-16 md:h-20 max-w-5xl mx-auto px-2 md:px-8 overflow-x-auto hide-scrollbar sm:flex-nowrap flex-nowrap"
    >
        {
            menuItems.map((item: any) => {
                const Icon = item.icon;
                return (
                    <a
                        href={item.href}
                        class="flex flex-col items-center justify-center min-w-[72px] md:min-w-[100px] shrink-0 group gap-1 md:gap-1.5 cursor-pointer py-2"
                    >
                        <div class="flex items-center justify-center px-4 py-1 md:px-5 md:py-1.5 rounded-[20px] group-hover:bg-custom-beige/10 transition-colors duration-200">
                            <Icon className="w-5 h-5 md:w-6 md:h-6 text-custom-piel dark:text-custom-beige/70 group-hover:text-custom-beige transition-transform duration-200 group-hover:scale-110" />
                        </div>
                        <span class="text-[10px] md:text-[13px] font-light font-neue tracking-wide text-custom-piel dark:text-custom-beige/70 group-hover:text-custom-beige text-center whitespace-normal leading-tight w-full px-1">
                            {item.title}
                        </span>
                    </a>
                );
            })
        }
    </div>
</nav>
