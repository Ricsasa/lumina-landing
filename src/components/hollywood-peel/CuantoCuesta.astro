---
import PriceCard from "../common/PriceCard.astro";
---

<section
    class="flex flex-col items-center md:px-6 scroll-mt-28 py-20 w-full"
    id="costos"
>
    <!-- Section Header -->
    <div class="mx-auto max-w-3xl text-center mb-12">
        <h2
            class="text-3xl md:text-5xl font-medium tracking-tight text-custom-piel dark:text-custom-beige font-fira"
        >
            ¿Cuánto cuesta?
        </h2>
        <p
            class="mt-4 text-base md:text-lg text-custom-oscuro dark:text-custom-piel font-light px-4"
        >
            Conoce nuestros precios y paquetes.
        </p>
    </div>

    <!-- Cards Container -->
    <div
        class="w-[calc(100vw-2em)] max-w-5xl mx-auto flex flex-col md:flex-row gap-6 md:gap-8"
    >
        <PriceCard
            title="Sesión Única"
            description="Ideal para probar el tratamiento de Hollywood Peel."
            price="$1,000"
        />

        <PriceCard
            title="Paquete de 4 Sesiones"
            description="Resultados óptimos para tu piel."
            price="$3,200"
        />

        <PriceCard
            title="Paquete de 6 Sesiones"
            description="El mejor valor por tu dinero."
            price="$4,200"
        />
    </div>
</section>
