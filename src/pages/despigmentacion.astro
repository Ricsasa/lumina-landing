---
import "../styles/global.css";

import Layout from "../layouts/Layout.astro";

import Body from "../components/Body.astro";

import InnerMenu from "../components/common/InnerMenu.astro";

import {
    CurrencyDollarIcon,
    PencilIcon,
    PhotoIcon,
    QuestionMarkCircleIcon,
} from "@heroicons/react/24/outline";

import ComoFunciona from "../components/despigmentacion/ComoFunciona.astro";

import Costos from "../components/despigmentacion/CuantoCuesta.astro";

import Galeria from "../components/despigmentacion/Galeria.jsx";

import PreguntasFrecuentes from "../components/despigmentacion/PreguntasFrecuentes.astro";

const menuItems = [
    {
        title: "¿Cómo funciona?",
        icon: PencilIcon,
        href: "#como-funciona",
    },
    {
        title: "¿Cuánto cuesta?",
        icon: CurrencyDollarIcon,
        href: "#costos",
    },
    {
        title: "Galeria",
        icon: PhotoIcon,
        href: "#galeria",
    },
    {
        title: "Preguntas frecuentes",
        icon: QuestionMarkCircleIcon,
        href: "#preguntas-frecuentes",
    },
];
---

<Layout>
    <Body>
        <InnerMenu
            title="Despigmentación facial y corporal"
            menuItems={menuItems}
        />
        <ComoFunciona />
        <Costos />
        <Galeria client:visible />
        <PreguntasFrecuentes />
    </Body>
</Layout>
