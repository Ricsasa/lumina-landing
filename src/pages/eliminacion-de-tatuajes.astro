---
import "../styles/global.css";

import Layout from "../layouts/Layout.astro";

import Body from "../components/Body.astro";

import InnerMenu from "../components/common/InnerMenu.astro";

import {
    CurrencyDollarIcon,
    PencilIcon,
    PhotoIcon,
    QuestionMarkCircleIcon,
} from "@heroicons/react/24/outline";

import ComoFunciona from "../components/eliminacion-de-tatuajes/ComoFunciona.astro";

import Costos from "../components/eliminacion-de-tatuajes/CuantoCuesta.astro";

import Galeria from "../components/eliminacion-de-tatuajes/Galeria.jsx";

import PreguntasFrecuentes from "../components/eliminacion-de-tatuajes/PreguntasFrecuentes.astro";

const menuItems = [
    {
        title: "¿Cómo funciona?",
        icon: PencilIcon,
        href: "/eliminacion-de-tatuajes/#como-funciona",
    },
    {
        title: "¿Cuánto cuesta?",
        icon: CurrencyDollarIcon,
        href: "/eliminacion-de-tatuajes/#costos",
    },
    /*
    {
        title: "Galeria",
        icon: PhotoIcon,
        href: "/eliminacion-de-tatuajes/#galeria",
    },
    */
    {
        title: "Preguntas frecuentes",
        icon: QuestionMarkCircleIcon,
        href: "/eliminacion-de-tatuajes/#preguntas-frecuentes",
    },
];

export const prerender = true;
export const seo = {
    title: `Eliminación de tatuajes`,
    description:
        "Lumina Estudio Laser | Elimina tatuajes con nuestros tratamientos avanzados de eliminación de tatuajes.",
};
---

<Layout seo={seo}>
    <Body>
        <InnerMenu title="Eliminación de tatuajes" menuItems={menuItems} />
        <ComoFunciona />
        <Costos />
        <!-- <Galeria client:only="react" /> -->
        <PreguntasFrecuentes />
    </Body>
</Layout>
